# Yerel ortam değişkenleri (ör. PORT). Döviz kutusu harici özet uç noktadan okunur; ek anahtar gerekmez.

# --- Üretim: gundemturkiye365.com ---
# Tek kanonik kök seçin (genelde www); apex’i (gundemturkiye365.com) buraya yazdığınız hosta 301 yönlendirin.
# PUBLIC_SITE_ORIGIN=https://www.gundemturkiye365.com
# SITE_URL, PUBLIC_SITE_ORIGIN ile aynı işe yarar (ikisinden biri yeterli).
# Nginx / Cloudflare arkasında istemci IP ve HTTPS için (gerekirse):
# TRUST_PROXY=1

# CORS: Ön yüz farklı kökten (ör. Cloudflare Pages) API’ye gidiyorsa buraya tam kök yazın. Boşsa tüm origin’lere GET açılır (yalnızca genel veri).
# CORS_ORIGIN=https://www.gundemturkiye365.com

# Görsel vekil (/api/image) dakikada IP başına en fazla istek (varsayılan 200)
# IMAGE_PROXY_RATE_MAX=200

# RSS: önbellek süresi (ms). Süre dolunca /api/news yeni RSS turu çeker (varsayılan 120000 = 2 dk)
# RSS_CACHE_MS=120000

# Site çıkış RSS’i (Telegram kanalı / IFTTT vb.): https://www.gundemturkiye365.com/rss.xml (aynı zamanda /feed.xml)
# Görseli olan haberlerde <enclosure> ile /api/image… adresi verilir (bot önizlemesi için).
# PUBLIC_SITE_ORIGIN veya SITE_URL tanımlı olmalı. Öğe sayısı 1–100, açıklama uzunluğu karakter.
# RSS_FEED_ITEM_LIMIT=40
# RSS_FEED_DESCRIPTION_MAX=600

# Google SEO: news-sitemap.xml ve robots.txt (yukarıdaki PUBLIC_SITE_ORIGIN ile aynı kök)
# Publisher Center → “Google News’te takip edin” yayın sayfası (yalnızca https://news.google.com/...).
# Tanımlıysa ana sayfa + haber kabuğu footer’ında bağlantı ve JSON-LD sameAs eklenir.
# GOOGLE_NEWS_PUBLICATION_URL=https://news.google.com/publications/...
# Publisher Center’daki yayın adı (news:name)
# NEWS_PUBLICATION_NAME=GündemTürkiye365.com
# Haber site haritası: en fazla kaç URL (Google üst sınırı 1000)
# NEWS_SITEMAP_ARTICLE_LIMIT=1000
# Site haritasına dahil edilecek en eski haber yaşı (saat, Google önerisi ~48)
# NEWS_SITEMAP_MAX_AGE_HOURS=48
# Genel sitemap.xml içinde kaç haber URL’si listelensin (0 = yalnızca ana sayfa)
# GENERAL_SITEMAP_HABER_LIMIT=300

# Haber arşivi (SQLite). Yeni RSS turunda kayıtlar güncellenir.
# Yayın zamanı (ts) üzerinden NEWS_DB_RETENTION_DAYS günden eski satırlar silinir; temizlik NEWS_DB_PURGE_INTERVAL_MS ile tekrarlanır (varsayılan 14 gün).
# NEWS_DB_RETENTION_DAYS=14
# NEWS_DB_PURGE_INTERVAL_MS=1209600000
# NEWS_DB_PATH=./data/news.sqlite
# NEWS_DISABLE_DB=1

# API listesinde (manşet+grid) görseli olmayanlara ikinci tur og:image (varsayılan 40)
# PAYLOAD_OG_ENRICH_MAX=40
